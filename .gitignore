.slither_venv/
git-pip.py
# Data files used by local runs (relayer-data, amp-data, etc.)
*-data/

# ---- JavaScript / TypeScript ----
**/node_modules/
# Don't commit package-lock.json for SDK libraries; consumers pin their own.
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml
# napi-rs native build outputs (regenerated by `npm run build:native`):
# the platform-specific .node binary, the JS loader, and the generated .d.ts.
amp-sdk/js/native/*.node
amp-sdk/js/native/amp-native.js
amp-sdk/js/native/amp-native.d.ts

# ---- AMP SDK generated bindings ----
# Generated bindings are produced by `amp-sdk/generate_bindings.sh` and
# by each language's build system. The following patterns hide them from
# version control because they are reproducible from the canonical schemas
# in `amp-sdk/schemas/*.capnp`.
#
# Note: `amp-sdk/schemas/generated/{cpp,csharp}/` IS intentionally tracked
# (these are the outputs that the C++ CMakeLists and the C# .csproj compile
# against, so a fresh clone builds without requiring the capnp compilers to
# be installed).
#
# Note: `amp-sdk/python/amp_sdk/generated/` IS intentionally tracked because
# those are stripped schema SOURCES (not bindings) that ship in the wheel
# and are loaded by pycapnp at runtime.
amp-sdk/csharp/generated/
amp-sdk/go/generated/
amp-sdk/rust/src/generated_*

# ---- Local development data ----
relayer-data/
amp-data/
anvil.log
secrets/
/amp-sdk/cpp/build-tests/
/amp-sdk/cpp/build-cpp-tests/
