# ---- Foundry / Solidity ----
# Keep lib/ submodules; ignore build artifacts.
# The two ABI JSONs below ARE committed because amp-relayer and
# amp-integration-tests `abigen!`/`include_str!` them at compile time
# (see Phase 0.1 of the release plan). Re-run `forge build` and recommit
# them whenever contracts/src/*.sol changes.
contracts/out/**
!contracts/out/AMPRegistry.sol/
contracts/out/AMPRegistry.sol/*
!contracts/out/AMPRegistry.sol/AMPRegistry.json
!contracts/out/AMPSettlement.sol/
contracts/out/AMPSettlement.sol/*
!contracts/out/AMPSettlement.sol/AMPSettlement.json
contracts/cache/
contracts/broadcast/
contracts/lib/

# ---- Editor / IDE ----
.vscode/
.idea/
*.tsbuildinfo

# ---- Build artifacts (all languages) ----
build/
dist/
.cache/
out/
lib/  # generic catch-all; doesn't affect contracts/lib above

