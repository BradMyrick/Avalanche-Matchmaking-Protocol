# =========================
# Network Selection
# =========================

# Target network name: "anvil" "fuji" or "mainnet"(not setup yet).
AMP_NETWORK=anvil

# =========================
# Anvil (Local Dev)
# =========================

# Local Anvil RPC URL
ANVIL_RPC_URL=http://127.0.0.1:8545

# Anvil chain ID (default)
ANVIL_CHAIN_ID=31337

# Anvil deployer private key (example only – DO NOT USE IN PROD)
# Replace in your real .env with your own key or the default Anvil key.
ANVIL_DEPLOYER_PRIVATE_KEY=

# =========================
# Fuji Testnet (C-Chain)
# =========================

# Fuji RPC URL (choose one)
# e.g. https://api.avax-test.network/ext/bc/C/rpc
# or   https://avalanche-fuji-c-chain-rpc.publicnode.com
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Fuji chain ID
FUJI_CHAIN_ID=43113

# Deployer private key for Fuji
DEPLOYER_PRIVATE_KEY=

# Public address of the Fuji deployer (for docs / verification only)
DEPLOYER_ADDRESS=0xDeAdBeEfDeAdBeEfDeAdBeEfDeAdBeEfDeAdBeEf

# =========================
# AMP Contract Addresses
# =========================

# Local Anvil deployment addresses (filled after local deploy)
ANVIL_AMP_REGISTRY_ADDRESS=
ANVIL_AMP_SETTLEMENT_ADDRESS=

# Fuji deployment addresses (fill in after Fuji deploy)
AMP_REGISTRY_ADDRESS=
AMP_SETTLEMENT_ADDRESS=

# =========================
# Verifier / Server Config
# =========================

# RPC URL used by amp-server and SDKs (you may set this to ANVIL_RPC_URL or FUJI_RPC_URL)
AMP_RPC_URL=${ANVIL_RPC_URL}

# Verifier private key (used by amp-server to sign results)
# DO NOT COMMIT REAL VALUE
AMP_VERIFIER_PRIVATE_KEY=

# Verifier public address (for on-chain config)
AMP_VERIFIER_ADDRESS=

# =========================
# SDK / Frontend Config
# =========================

# Optional: default gameId or ruleset IDs used by examples / demos
# if I don't get ID generation finished beforehand
AMP_DEFAULT_GAME_ID=6742069

# Optional: base URL for any HTTP APIs used by demos (if applicable)
AMP_API_BASE_URL=http://127.0.0.1:3000

# =========================
# Telemetry / Logging
# =========================

# Path where telemetry traces should be written by examples
AMP_TELEMETRY_OUTPUT_DIR=./telemetry-out


# =========================
# Fuji Testnet (C-Chain)
# =========================
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_CHAIN_ID=43113

# Deployer private key for Fuji (for admin operations only)
DEPLOYER_PRIVATE_KEY=

# Public address of the Fuji deployer
DEPLOYER_ADDRESS=

# =========================
# AMP Contract Addresses (Fuji)
# =========================
AMP_REGISTRY_ADDRESS=0x8479491220D8d56F32f1a4A5Cc827cf056a9aC34
AMP_SETTLEMENT_ADDRESS=0xecD9C6C1727d610A7C0Aeb3a37A6278049791a24