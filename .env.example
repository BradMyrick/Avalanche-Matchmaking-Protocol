# =========================
# Anvil (Local Dev)
# =========================

ANVIL_RPC_URL=http://127.0.0.1:8545
ANVIL_CHAIN_ID=31337
ANVIL_DEPLOYER_PRIVATE_KEY=
ANVIL_AMP_REGISTRY_ADDRESS=
ANVIL_AMP_SETTLEMENT_ADDRESS=

# =========================
# Fuji Testnet (C-Chain)
# =========================

FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=0xDeAdBeEfDeAdBeEfDeAdBeEfDeAdBeEfDeAdBeEf

# =========================
# AMP Contract Addresses
# =========================

AMP_REGISTRY_ADDRESS=
AMP_SETTLEMENT_ADDRESS=

# =========================
# amp-server (Matchmaker/Verifier)
# =========================

AMP_ADDR=0.0.0.0:50051
AMP_PORT=50051
AMP_DB_PATH=./amp-data
# EIP-712 domain chain ID for outcome signatures. Both names are accepted
# by the server; AMP_EIP712_CHAIN_ID is preferred (AMP_CHAIN_ID is a legacy alias).
AMP_EIP712_CHAIN_ID=43113
AMP_SETTLEMENT_ADDRESS=
VERIFIER_KEY=                    # Ethereum private key for match outcome signing (prefer VERIFIER_KEY_FILE)
VERIFIER_KEY_FILE=               # Path to file containing verifier private key

# TLS (optional — if both set, TLS is required; if neither set, plain TCP)
AMP_TLS_CERT_FILE=
AMP_TLS_KEY_FILE=

# Rate limiting
AMP_MAX_CONCURRENT=1000          # Max simultaneous connections
AMP_MAX_PER_IP_PER_MIN=60        # Max new connections per IP per minute

# Worker threads (defaults to number of CPU cores)
AMP_WORKERS=                     # Number of SO_REUSEPORT worker threads (default: num_cpus)

# Observability — Prometheus /metrics endpoint (release Phase 7).
# Set to "disabled" to turn off. Default: 127.0.0.1:9100.
AMP_METRICS_ADDR=127.0.0.1:9100
# Metrics exposed: amp_matches_created_total, amp_matches_settled_total,
# amp_settlement_desync_total, amp_auth_failures_total, amp_player_disconnects_total,
# amp_queue_depth, amp_active_matches.

# Relayer client (runs on dedicated thread, persistent connection)
RELAYER_RPC_ADDR=localhost:50052
RELAYER_API_KEY=                 # Required by default. API key for relayer authentication (prefer RELAYER_API_KEY_FILE)
RELAYER_API_KEY_FILE=            # Path to file containing relayer API key
# AMP_ALLOW_UNAUTHENTICATED_RELAYER=0  # Set to 1 to bypass the API key requirement (NOT RECOMMENDED — see SECURITY_REVIEW.md S11)

# Telemetry client (runs on dedicated thread, persistent connection)
TELEMETRY_ADDR=127.0.0.1:4317

# =========================
# amp-relayer (Settlement Bridge)
# =========================

CONTRACT_REGISTRY=
CONTRACT_SETTLEMENT=
RELAYER_PRIVATE_KEY=             # Ethereum private key for settlement txs (prefer RELAYER_PRIVATE_KEY_FILE)
RELAYER_PRIVATE_KEY_FILE=        # Path to file containing relayer private key
RPC_PORT=50052
RELAYER_DB_PATH=./relayer-data
RELAYER_MAX_RETRIES=5
RELAYER_RETRY_DELAY_MS=1000
RELAYER_GAS_BUMP_PERCENT=10
RELAYER_MAX_CONNECTIONS=50       # Max concurrent RPC connections to relayer
RELAYER_MAX_PER_IP=10            # Max concurrent connections per source IP (DoS mitigation)

# Observability — Prometheus /metrics endpoint for the relayer (Phase 7).
# Default: 127.0.0.1:9101. Set to "disabled" to turn off.
RELAYER_METRICS_ADDR=127.0.0.1:9101
# Metrics exposed: amp_settlements_submitted_total, amp_settlements_confirmed_total,
# amp_settlements_dead_lettered_total, amp_settlement_retries_total.

# TLS (optional — if both set, TLS is required)
RELAYER_TLS_CERT_FILE=
RELAYER_TLS_KEY_FILE=

# API key authentication — REQUIRED by default on the relayer.
# Set AMP_ALLOW_UNAUTHENTICATED_RELAYER=1 to bypass (NOT RECOMMENDED — see SECURITY_REVIEW.md S11).
RELAYER_API_KEY=                 # Single API key (prefer RELAYER_API_KEY_FILE)
RELAYER_API_KEY_FILE=            # Path to file containing API key (one per line)
# RELAYER_API_KEYS=              # Comma-separated list of additional API keys

# =========================
# Telemetry Receiver
# =========================

TELEMETRY_MAX_CONNECTIONS=100    # Max concurrent telemetry connections

# =========================
# SDK / Frontend Config
# =========================

AMP_DEFAULT_GAME_ID=6742069
AMP_API_BASE_URL=http://127.0.0.1:3000

# EIP-712 outcome signature domain parameters (used by all SDKs and any
# external signer that needs to compute the canonical digest). Defaults
# match the server's SigningConfig; override at app startup to match
# your deployment.
# AMP_EIP712_CHAIN_ID=43113
# AMP_EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000
