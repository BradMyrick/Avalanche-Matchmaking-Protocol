{
  "name": "@avalanche-matchmaking-protocol/amp-sdk",
  "version": "0.1.0",
  "description": "Avalanche Matchmaking Protocol SDK for JavaScript/TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "avalanche",
    "matchmaking",
    "blockchain",
    "gaming",
    "protocol"
  ],
  "author": "Avalanche Matchmaking Protocol Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/avalanche-matchmaking-protocol/amp.git"
  },
  "dependencies": {
    "@ava-labs/avalanchejs": "^5.0.0",
    "axios": "^1.6.0",
    "bn.js": "^5.2.0",
    "bs58": "^5.0.0",
    "capnp-ts": "^0.9.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}